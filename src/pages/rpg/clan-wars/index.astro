---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";

export const prerender = true;

const clanWars = (await getCollection("clanWars")).sort(
    (a, b) => b.data.startsAt.valueOf() - a.data.startsAt.valueOf(),
);

const formatDate = (date: Date, timeZone: string) =>
    new Intl.DateTimeFormat("es-PE", {
        timeZone,
        day: "2-digit",
        month: "short",
        year: "numeric",
    }).format(date);
const formatTime = (date: Date, timeZone: string) =>
    new Intl.DateTimeFormat("es-PE", {
        timeZone,
        hour: "2-digit",
        minute: "2-digit",
    }).format(date);
const statusLabels = {
    announced: "Próximo enfrentamiento",
    completed: "Finalizado",
    cancelled: "Cancelado",
};
---

<BaseLayout
    title="Clan Wars · RPG Temporada III | Mycraft Network"
    description="Anuncios oficiales y archivo de las guerras de clanes de RPG Temporada III en Mycraft Network."
>
    <main class="wars-page" data-wars-page>
        <header class="wars-hero shell">
            <div class="hero-copy">
                <p class="eyebrow" data-hero-item>RPG · Temporada III</p>
                <h1 data-hero-item>El territorio no se pide.<br /><em>Se conquista.</em></h1>
                <p class="hero-lede" data-hero-item>
                    Cada Clan War deja un solo nombre en pie. Consultá los
                    próximos enfrentamientos y el registro oficial de quienes
                    lograron dominar el KOTH.
                </p>
            </div>
            <div class="season-stamp" aria-label="Temporada 3" data-hero-item>
                <span>Temporada</span><strong class="number">03</strong>
                <small>RPG</small>
            </div>
        </header>

        <section class="archive shell" aria-labelledby="archive-title">
            <div class="section-heading" data-reveal>
                <div>
                    <p class="section-kicker">Registro oficial</p>
                    <h2 id="archive-title">Guerras de clanes</h2>
                </div>
                <span class="event-count number">{String(clanWars.length).padStart(2, "0")} eventos</span>
            </div>

            <div class="war-list">
                {
                    clanWars.map(({ id, data }, index) => (
                        <article
                            class:list={["war-card", `status-${data.status}`]}
                            data-war-card
                        >
                            <a
                                class="card-media"
                                href={`/rpg/clan-wars/${id}`}
                                aria-label={`Ver ${data.title}`}
                            >
                                <img
                                    src={data.cover}
                                    alt={data.coverAlt}
                                    width="800"
                                    height="450"
                                    loading={index === 0 ? "eager" : "lazy"}
                                    decoding="async"
                                />
                                <span class="card-shade" aria-hidden="true" />
                                <span class="status-badge">
                                    <i aria-hidden="true" />
                                    {statusLabels[data.status]}
                                </span>
                            </a>

                            <div class="card-body">
                                <div class="card-heading">
                                    <div>
                                        <p>KOTH · {data.koth.name}</p>
                                        <h3>
                                            <a href={`/rpg/clan-wars/${id}`}>{data.title}</a>
                                        </h3>
                                    </div>
                                    <span class="season-number number">S{String(data.season).padStart(2, "0")}</span>
                                </div>

                                <dl class="card-facts">
                                    <div>
                                        <dt>Fecha</dt>
                                        <dd>
                                            <time datetime={data.startsAt.toISOString()}>
                                                {formatDate(data.startsAt, data.timezone)}
                                            </time>
                                        </dd>
                                    </div>
                                    <div>
                                        <dt>Hora</dt>
                                        <dd class="number">{formatTime(data.startsAt, data.timezone)}</dd>
                                    </div>
                                    <div>
                                        <dt>Objetivo</dt>
                                        <dd class="number">
                                            {data.objective.value.toLocaleString("es-ES")} {data.objective.unit}
                                        </dd>
                                    </div>
                                </dl>

                                <div class="card-footer">
                                    <span>
                                        <b>{data.rewards.length}</b> recompensas en juego
                                    </span>
                                    <a class="card-link" href={`/rpg/clan-wars/${id}`}>
                                        Ver anuncio <span aria-hidden="true">→</span>
                                    </a>
                                </div>
                            </div>
                        </article>
                    ))
                }
            </div>
        </section>
    </main>
</BaseLayout>

<script>
    import gsap from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    const page = document.querySelector<HTMLElement>("[data-wars-page]");
    if (page) {
        const media = gsap.matchMedia();
        media.add("(prefers-reduced-motion: no-preference)", () => {
            const heroItems = page.querySelectorAll("[data-hero-item]");
            const reveals = page.querySelectorAll("[data-reveal]");
            const cards = page.querySelectorAll<HTMLElement>("[data-war-card]");
            const intro = gsap.timeline({ defaults: { ease: "power3.out" } });

            intro.from(heroItems, {
                autoAlpha: 0,
                y: 20,
                duration: 0.65,
                stagger: 0.075,
                clearProps: "opacity,visibility,transform",
            });

            const targets = [...reveals, ...cards];
            gsap.set(targets, { autoAlpha: 0, y: 24 });
            const triggers = ScrollTrigger.batch(targets, {
                start: "top 90%",
                once: true,
                onEnter: (batch) =>
                    gsap.to(batch, {
                        autoAlpha: 1,
                        y: 0,
                        duration: 0.6,
                        stagger: 0.08,
                        ease: "power3.out",
                        overwrite: "auto",
                    }),
            });

            return () => triggers.forEach((trigger) => trigger.kill());
        });

        media.add(
            "(hover: hover) and (pointer: fine) and (prefers-reduced-motion: no-preference)",
            () => {
                const cleanups = Array.from(
                    page.querySelectorAll<HTMLElement>("[data-war-card]"),
                ).map((card) => {
                    const image = card.querySelector("img");
                    const enter = () =>
                        gsap.to(image, { scale: 1.045, duration: 0.6, ease: "power3.out" });
                    const leave = () =>
                        gsap.to(image, { scale: 1, duration: 0.7, ease: "power3.out" });
                    card.addEventListener("mouseenter", enter);
                    card.addEventListener("mouseleave", leave);
                    return () => {
                        card.removeEventListener("mouseenter", enter);
                        card.removeEventListener("mouseleave", leave);
                    };
                });
                return () => cleanups.forEach((cleanup) => cleanup());
            },
        );
    }
</script>

<style>
    .wars-page {
        min-height: calc(100vh - 88px);
        overflow: hidden;
    }
    .wars-hero {
        position: relative;
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        min-height: 470px;
        align-items: center;
        gap: 3rem;
        padding-block: clamp(4rem, 9vw, 7.5rem);
    }
    .wars-hero::before {
        content: "CW";
        position: absolute;
        z-index: -1;
        top: 50%;
        right: 7%;
        color: rgb(255 255 255 / 2.4%);
        font-family: var(--display);
        font-size: clamp(14rem, 32vw, 29rem);
        font-weight: 700;
        letter-spacing: -.09em;
        line-height: .7;
        transform: translateY(-50%);
    }
    .hero-copy h1 {
        max-width: 780px;
        margin: 0;
        font-family: var(--display);
        font-size: clamp(2.5rem, 5.2vw, 4.75rem);
        font-weight: 650;
        letter-spacing: -.012em;
        line-height: 1.02;
    }
    .hero-copy h1 em {
        color: var(--accent-bright);
        font-style: normal;
    }
    .hero-lede {
        max-width: 62ch;
        margin: 1.6rem 0 0;
        color: var(--muted);
        font-size: clamp(.95rem, 1.7vw, 1.08rem);
    }
    .season-stamp {
        display: grid;
        width: 142px;
        aspect-ratio: 1;
        place-content: center;
        border: 1px solid var(--line-bright);
        background: rgb(14 17 24 / 82%);
        text-align: center;
        transform: rotate(3deg);
        box-shadow: 12px 12px 0 rgb(228 87 46 / 9%);
    }
    .season-stamp span,
    .season-stamp small {
        color: var(--muted);
        font-size: .62rem;
        font-weight: 800;
        letter-spacing: .16em;
        text-transform: uppercase;
    }
    .season-stamp strong {
        margin-block: -.08em;
        color: var(--text);
        font-size: 4.2rem;
        font-weight: 400;
        line-height: 1;
    }
    .season-stamp small { color: var(--accent-bright); }

    .archive { padding-bottom: clamp(4.5rem, 9vw, 8rem); }
    .section-heading {
        display: flex;
        align-items: end;
        justify-content: space-between;
        gap: 2rem;
        margin-bottom: 1.35rem;
        padding-bottom: 1rem;
        border-bottom: 1px solid var(--line);
    }
    .section-heading p { margin: 0 0 .4rem; }
    .section-heading h2 {
        margin: 0;
        font-family: var(--display);
        font-size: clamp(1.65rem, 3vw, 2.35rem);
        letter-spacing: 0;
        line-height: 1;
    }
    .event-count {
        color: var(--faint);
        font-family: var(--body);
        font-size: .72rem;
        letter-spacing: .08em;
        text-transform: uppercase;
    }
    .war-list { display: grid; gap: 1.25rem; }
    .war-card {
        display: grid;
        grid-template-columns: minmax(300px, .88fr) minmax(0, 1.12fr);
        overflow: hidden;
        border: 1px solid var(--line);
        border-radius: 15px;
        background: #0d1016;
        box-shadow: 0 24px 80px rgb(0 0 0 / 22%);
    }
    .card-media { position: relative; min-height: 330px; overflow: hidden; }
    .card-media img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        will-change: transform;
    }
    .card-shade {
        position: absolute;
        inset: 0;
        background: linear-gradient(90deg, transparent 45%, #0d1016 100%), linear-gradient(0deg, rgb(4 5 8 / 65%), transparent 55%);
    }
    .status-badge {
        position: absolute;
        top: 1.2rem;
        left: 1.2rem;
        display: inline-flex;
        align-items: center;
        gap: .5rem;
        padding: .52rem .72rem;
        border: 1px solid rgb(255 113 71 / 42%);
        border-radius: 99px;
        background: rgb(7 9 13 / 82%);
        font-size: .65rem;
        font-weight: 800;
        letter-spacing: .08em;
        text-transform: uppercase;
        backdrop-filter: blur(10px);
    }
    .status-badge i {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: var(--accent-bright);
        box-shadow: 0 0 0 4px rgb(255 113 71 / 14%);
    }
    .card-body {
        display: flex;
        min-width: 0;
        flex-direction: column;
        justify-content: center;
        padding: clamp(1.5rem, 4vw, 3rem);
    }
    .card-heading { display: flex; justify-content: space-between; gap: 1rem; }
    .card-heading p {
        margin: 0 0 .45rem;
        color: var(--accent-bright);
        font-size: .69rem;
        font-weight: 850;
        letter-spacing: .12em;
        text-transform: uppercase;
    }
    .card-heading h3 {
        margin: 0;
        font-family: var(--display);
        font-size: clamp(1.55rem, 2.7vw, 2.15rem);
        letter-spacing: 0;
        line-height: 1.12;
    }
    .season-number { color: var(--faint); font-size: .85rem; }
    .card-facts {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        margin: 2rem 0;
        padding-block: 1.1rem;
        border-block: 1px solid var(--line);
    }
    .card-facts div { padding-inline: 1rem; border-right: 1px solid var(--line); }
    .card-facts div:first-child { padding-left: 0; }
    .card-facts div:last-child { padding-right: 0; border-right: 0; }
    .card-facts dt {
        margin-bottom: .32rem;
        color: var(--faint);
        font-size: .6rem;
        font-weight: 800;
        letter-spacing: .1em;
        text-transform: uppercase;
    }
    .card-facts dd { margin: 0; color: var(--text); font-size: .85rem; font-weight: 700; }
    .card-footer { display: flex; align-items: center; justify-content: space-between; gap: 1rem; }
    .card-footer > span { color: var(--muted); font-size: .76rem; }
    .card-footer > span b { color: var(--gold); }
    .card-link { color: var(--text); font-size: .78rem; font-weight: 800; }
    .card-link span { display: inline-block; margin-left: .35rem; color: var(--accent-bright); transition: transform 180ms ease; }
    .card-link:hover span { transform: translateX(4px); }

    @media (max-width: 820px) {
        .wars-hero { min-height: 410px; grid-template-columns: 1fr; gap: 2rem; }
        .season-stamp { display: none; }
        .war-card { grid-template-columns: 1fr; }
        .card-media { min-height: clamp(220px, 48vw, 320px); }
        .card-shade { background: linear-gradient(0deg, #0d1016 0%, transparent 55%); }
    }
    @media (max-width: 560px) {
        .wars-hero { min-height: 370px; padding-block: 3.5rem; }
        .hero-copy h1 { font-size: clamp(2.35rem, 10.5vw, 3.25rem); line-height: 1.05; }
        .hero-copy h1 br { display: none; }
        .section-heading { align-items: start; }
        .event-count { padding-top: .35rem; white-space: nowrap; }
        .card-media { min-height: 210px; }
        .card-body { padding: 1.25rem; }
        .card-facts { grid-template-columns: 1fr 1fr; gap: 1rem 0; }
        .card-facts div { padding-inline: .8rem; }
        .card-facts div:nth-child(2) { border-right: 0; }
        .card-facts div:nth-child(3) { grid-column: 1 / -1; padding: .9rem 0 0; border-top: 1px solid var(--line); border-right: 0; }
        .card-footer { align-items: end; }
        .card-footer > span { max-width: 10rem; }
    }
    @media (max-width: 380px) {
        .wars-hero { min-height: 340px; padding-block: 3rem; }
        .hero-copy h1 { font-size: 2.15rem; }
        .hero-lede { font-size: .88rem; }
        .section-heading { gap: .75rem; }
        .event-count { font-size: .62rem; }
        .card-media { min-height: 185px; }
        .card-footer { align-items: start; flex-direction: column; }
    }
</style>
