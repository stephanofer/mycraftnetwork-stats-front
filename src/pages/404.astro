---
import StatusState from "@/components/StatusState.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
export const prerender = true;
Astro.response.status = 404;
---

<BaseLayout title="Página no encontrada | Mycraft Network" noindex>
    <main class="page shell">
        <StatusState
            code={404}
            title="Esta ruta quedó fuera del mapa"
            message="El registro o la página que buscás no existe. Podés volver a la competición activa de RPG Temporada III."
        />
    </main>
</BaseLayout>
