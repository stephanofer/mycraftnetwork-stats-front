---
import BaseLayout from "@/layouts/BaseLayout.astro";
export const prerender = true;
---

<BaseLayout title="Survival 26.2 próximamente | Mycraft Network" description="Survival 26.2 será una nueva experiencia competitiva independiente en Mycraft Network.">
  <main class="smp-page">
    <div class="shell content reveal">
      <p class="eyebrow">Modalidad en construcción</p>
      <h1>Una nueva supervivencia está por comenzar.</h1>
      <p>Survival 26.2 tendrá identidad, progresión y métricas propias. Hasta que sus datos representen una competición real, no publicaremos rankings ni estadísticas simuladas.</p>
      <div class="actions"><span class="seal">SMP</span><a class="button primary" href="/">Volver al centro</a></div>
    </div>
  </main>
</BaseLayout>

<style>
  .smp-page { position: relative; display: grid; min-height: calc(100vh - 164px); align-items: end; overflow: hidden; padding-block: 5rem; background: linear-gradient(90deg, rgb(7 9 13 / 98%) 10%, rgb(7 9 13 / 40%)), url('/images/image2.webp') center/cover; }
  .smp-page::after { content: "PRÓXIMAMENTE"; position: absolute; right: -1rem; bottom: 0; color: rgb(255 255 255 / 4%); font-family: var(--display); font-size: clamp(4rem, 15vw, 14rem); font-weight: 700; line-height: .7; writing-mode: vertical-rl; }
  .content { position: relative; z-index: 1; }
  h1 { max-width: 12ch; margin: 0; font-family: var(--display); font-size: clamp(3rem, 9vw, 7.5rem); letter-spacing: -.025em; line-height: 1.06; }
  .content > p:not(.eyebrow) { max-width: 58ch; margin: 1.5rem 0; color: #b6bbc5; }
  .actions { display: flex; align-items: center; gap: 1rem; }
  .seal { display: grid; width: 54px; height: 54px; place-items: center; border: 1px solid var(--line-bright); border-radius: 50%; color: var(--muted); font-family: var(--numeric); font-size: .7rem; }
</style>
