---
import type { RankingPage } from "@/modules/rankings/ranking.types";
import { formatNumber, metricLabels } from "@/presentation";
import PlayerIdentity from "./PlayerIdentity.astro";

interface Props { ranking: RankingPage; }
const { ranking } = Astro.props;
const podium = ranking.entries.filter((entry) => entry.position <= 3);
const rows = ranking.entries.filter((entry) => entry.position > 3);
---

{ranking.partialFailures.length > 0 && <p class="partial" role="status">Identidad visual degradada: algunos rangos o skins no pudieron cargarse.</p>}

{ranking.entries.length === 0 ? (
  <section class="empty panel"><span class="number">00</span><h2>Sin marcas registradas</h2><p>Esta categoría todavía no tiene actividad competitiva válida.</p></section>
) : (
  <>
    <section class="podium" aria-label="Podio de la categoría">
      {podium.map((entry) => (
        <article class={`podium-card place-${entry.position}`}>
          <span class="place number">#{entry.position}</span>
          <PlayerIdentity uuid={entry.uuid} nickname={entry.nickname} rank={entry.rank} skin={entry.skin} eager={entry.position === 1} />
          <strong class="score number">{formatNumber(entry.value)}</strong>
          <span class="metric">{metricLabels[ranking.metric]}</span>
          <span class="podium-context">
            <small>{entry.distanceToHigher === null ? "Líder o empate" : `-${formatNumber(entry.distanceToHigher)} al superior`}</small>
            <small>Día {entry.dailyDelta > 0 ? "+" : ""}{formatNumber(entry.dailyDelta)} · Semana {entry.weeklyDelta > 0 ? "+" : ""}{formatNumber(entry.weeklyDelta)}</small>
          </span>
        </article>
      ))}
    </section>

    {rows.length > 0 && <section class="board panel" role="table" aria-label={`Ranking de ${metricLabels[ranking.metric]}`} aria-colcount="6">
      <div class="board-head" role="row"><span role="columnheader">Pos.</span><span role="columnheader">Competidor</span><span role="columnheader">Total</span><span role="columnheader">Distancia superior</span><span role="columnheader">Variación diaria</span><span role="columnheader">Variación semanal</span></div>
      {rows.map((entry, index) => (
        <div class="row reveal" role="row" aria-rowindex={index + 2} style={`animation-delay:${Math.min(index * 35, 350)}ms`}>
          <span class="position number" role="cell">{String(entry.position).padStart(2, "0")}</span>
          <span class="identity-cell" role="cell"><PlayerIdentity uuid={entry.uuid} nickname={entry.nickname} rank={entry.rank} skin={entry.skin} href={`/player/${encodeURIComponent(entry.nickname)}`} /></span>
          <span class="datum total" role="cell"><small>Total</small><b class="number">{formatNumber(entry.value)}</b></span>
          <span class="datum" role="cell"><small>Distancia superior</small>{entry.distanceToHigher === null ? "Líder o empate" : `-${formatNumber(entry.distanceToHigher)}`}</span>
          <span class:list={["datum delta", { positive: entry.dailyDelta > 0 }]} role="cell"><small>Variación diaria</small>{entry.dailyDelta > 0 ? "+" : ""}{formatNumber(entry.dailyDelta)}</span>
          <span class:list={["datum delta", { positive: entry.weeklyDelta > 0 }]} role="cell"><small>Variación semanal</small>{entry.weeklyDelta > 0 ? "+" : ""}{formatNumber(entry.weeklyDelta)}</span>
        </div>
      ))}
    </section>}
  </>
)}

<style>
  .partial { margin: 1rem 0; padding: .7rem 1rem; border-left: 3px solid var(--gold); background: rgb(232 189 99 / 8%); color: #d9c797; font-size: .8rem; }
  .podium { display: grid; grid-template-columns: repeat(3, 1fr); gap: .75rem; margin: 2rem 0 1rem; }
  .podium-card { position: relative; display: grid; grid-template-columns: 1fr auto; gap: .6rem 1rem; align-items: center; min-width: 0; padding: 1.15rem; overflow: hidden; border: 1px solid var(--line); border-top: 2px solid var(--medal, var(--bronze)); border-radius: var(--radius); background: linear-gradient(120deg, color-mix(in srgb, var(--medal) 9%, var(--surface)), var(--surface)); }
  .podium-card::after { content: attr(class); position: absolute; right: -.3rem; bottom: -1.8rem; color: rgb(255 255 255 / 3%); font-family: var(--numeric); font-size: 6rem; }
  .place-1 { --medal: var(--gold); } .place-2 { --medal: var(--silver); } .place-3 { --medal: var(--bronze); }
  .place { color: var(--medal); font-size: 1rem; }
  .score { color: var(--medal); font-size: 1.35rem; text-align: right; }
  .metric { grid-column: 2; color: var(--muted); font-size: .65rem; text-align: right; text-transform: uppercase; }
  .podium-context { grid-column: 1 / -1; display: flex; justify-content: space-between; gap: .5rem; padding-top: .55rem; border-top: 1px solid var(--line); color: var(--faint); font-size: .62rem; }
  .board { overflow: hidden; box-shadow: none; }
  .board-head, .row { display: grid; grid-template-columns: 65px minmax(180px, 1.6fr) repeat(4, minmax(100px, .8fr)); align-items: center; gap: 1rem; }
  .board-head { padding: .7rem 1rem; border-bottom: 1px solid var(--line); color: var(--faint); font-size: .65rem; font-weight: 800; letter-spacing: .08em; text-transform: uppercase; }
  .row { min-height: 69px; padding: .55rem 1rem; border-bottom: 1px solid var(--line); transition: background 150ms ease, padding-left 150ms ease; }
  .row:last-child { border: 0; }
  .row:hover { padding-left: 1.25rem; background: rgb(255 255 255 / 3%); }
  .position { color: var(--muted); font-size: 1.1rem; }
  .datum { color: var(--muted); font-size: .78rem; font-variant-numeric: tabular-nums; }
  .datum small { display: none; }
  .total b { color: var(--text); font-size: 1rem; }
  .delta.positive { color: var(--success); }
  .empty { margin-top: 2rem; padding: 4rem 2rem; text-align: center; }
  .empty span { color: var(--faint); font-size: 3rem; } .empty h2 { margin: .5rem 0; font-family: var(--display); } .empty p { color: var(--muted); }
  @media (max-width: 900px) { .podium { grid-template-columns: 1fr; } .podium-card { min-height: 86px; } .board-head { position: absolute; width: 1px; height: 1px; overflow: hidden; clip: rect(0 0 0 0); } .board { display: grid; gap: .65rem; overflow: visible; border: 0; background: none; } .row { grid-template-columns: 40px 1fr 1fr; gap: .8rem; padding: 1rem; border: 1px solid var(--line); border-radius: var(--radius); background: var(--surface); } .identity-cell { grid-column: 2 / -1; } .datum { display: flex; flex-direction: column; } .datum small { display: block; margin-bottom: .15rem; color: var(--faint); font-size: .55rem; text-transform: uppercase; } }
  @media (max-width: 500px) { .row { grid-template-columns: 32px 1fr 1fr; } .position { grid-row: span 3; align-self: start; } }
</style>
