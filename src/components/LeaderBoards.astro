---
import type { RankingPage } from "@/modules/rankings/ranking.types";
import { formatNumber, metricLabels } from "@/presentation";
import PlayerIdentity from "./PlayerIdentity.astro";

interface Props {
    ranking: RankingPage;
}

const { ranking } = Astro.props;
const placeLabels: Record<number, string> = {
    1: "Primero",
    2: "Segundo",
    3: "Tercero",
};
const entries = ranking.entries.map((entry) => ({
    ...entry,
    isTopThree: entry.position <= 3,
    placeClass: entry.position <= 3 ? `place-${entry.position}` : undefined,
}));
---

{
    ranking.partialFailures.length > 0 && (
        <p class="partial" role="status">
            Identidad visual degradada: algunos rangos o skins no pudieron
            cargarse.
        </p>
    )
}

{
    ranking.entries.length === 0 ? (
        <section class="empty panel">
            <span class="number">00</span>
            <h2>Sin marcas registradas</h2>
            <p>Esta categoría todavía no tiene actividad competitiva válida.</p>
        </section>
    ) : (
        <section
            class="board panel"
            role="table"
            aria-label={`Ranking de ${metricLabels[ranking.metric]}`}
            aria-colcount="5"
        >
            <div class="board-head" role="row">
                <span role="columnheader">Pos.</span>
                <span role="columnheader">Competidor</span>
                <span role="columnheader">{metricLabels[ranking.metric]}</span>
                <span role="columnheader">Para subir</span>
                <span role="columnheader">Variación diaria</span>
            </div>

            {entries.map((entry, index) => (
                <div
                    class:list={[
                        "row",
                        "reveal",
                        entry.placeClass,
                        {
                            "top-three": entry.isTopThree,
                            "top-ten": entry.position <= 10,
                        },
                    ]}
                    role="row"
                    aria-rowindex={index + 2}
                    style={`animation-delay:${Math.min(index * 35, 350)}ms`}
                >
                    <span class="position number" role="cell">
                        <b>{String(entry.position).padStart(2, "0")}</b>
                        {entry.isTopThree && (
                            <small>{placeLabels[entry.position]}</small>
                        )}
                    </span>

                    <span class="identity-cell" role="cell">
                        <PlayerIdentity
                            uuid={entry.uuid}
                            nickname={entry.nickname}
                            rank={entry.rank}
                            skin={entry.skin}
                            href={`/player/${encodeURIComponent(entry.nickname)}`}
                            eager={entry.position === 1}
                        />
                    </span>

                    <span class="datum total" role="cell">
                        <small>{metricLabels[ranking.metric]}</small>
                        <b class="number">{formatNumber(entry.value)}</b>
                    </span>

                    <span class="datum distance" role="cell">
                        <small>Para subir</small>
                        {entry.distanceToHigher === null
                            ? entry.position === 1
                                ? "Líder"
                                : "Empate"
                            : `+${formatNumber(entry.distanceToHigher)}`}
                    </span>

                    <span
                        class:list={[
                            "datum",
                            "delta",
                            {
                                positive: entry.dailyDelta > 0,
                                negative: entry.dailyDelta < 0,
                            },
                        ]}
                        role="cell"
                    >
                        <small>Variación diaria</small>
                        {entry.dailyDelta === 0
                            ? "Sin cambio"
                            : `${entry.dailyDelta > 0 ? "+" : ""}${formatNumber(entry.dailyDelta)}`}
                    </span>
                </div>
            ))}
        </section>
    )
}

<style>
    .partial {
        margin: 1rem 0;
        padding: 0.7rem 1rem;
        border-left: 3px solid var(--gold);
        background: rgb(232 189 99 / 8%);
        color: #d9c797;
        font-size: 0.8rem;
    }

    .board {
        margin-top: 2rem;
        overflow: hidden;
        background: #0e1118;
        box-shadow: none;
    }
    .board-head,
    .row {
        display: grid;
        grid-template-columns: 64px minmax(200px, 1.7fr) minmax(
                105px,
                0.72fr
            ) minmax(110px, 0.75fr) minmax(125px, 0.85fr);
        align-items: center;
        gap: 1rem;
    }
    .board-head {
        padding: 0.78rem 1rem;
        border-bottom: 1px solid var(--line);
        background: #090c11;
        color: var(--faint);
        font-size: 0.65rem;
        font-weight: 800;
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }
    .row {
        --medal: var(--cyan);
        min-height: 74px;
        padding: 0.65rem 1rem;
        border-bottom: 1px solid var(--line);
        transition:
            background 150ms ease,
            border-color 150ms ease;
    }
    .row:last-child {
        border-bottom: 0;
    }
    .row:nth-child(odd) {
        background: #10141c;
    }
    .row:hover {
        background: #151a24;
    }

    .row.top-three {
        min-height: 94px;
        border-left: 4px solid var(--medal);
        background: linear-gradient(
            90deg,
            color-mix(in srgb, var(--medal) 10%, #151923),
            #0e1118 58%
        );
    }
    .row.top-three:hover {
        background: linear-gradient(
            90deg,
            color-mix(in srgb, var(--medal) 14%, #171c26),
            #121620 65%
        );
    }
    .place-1 {
        --medal: var(--gold);
    }
    .place-2 {
        --medal: var(--silver);
    }
    .place-3 {
        --medal: var(--bronze);
    }
    .row.top-ten:not(.top-three) {
        border-left: 2px solid rgb(85 214 190 / 55%);
    }

    .position {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 0.2rem;
        color: var(--muted);
    }
    .position b {
        font-size: 1.15rem;
        font-weight: 650;
    }
    .position small {
        color: var(--medal);
        font-family: var(--body);
        font-size: 0.52rem;
        font-weight: 850;
        letter-spacing: 0.07em;
        text-transform: uppercase;
    }
    .top-three .position b {
        color: var(--medal);
        font-size: 1.45rem;
    }
    .top-ten:not(.top-three) .position b {
        color: var(--cyan);
    }

    .identity-cell {
        min-width: 0;
    }
    .top-three :global(.avatar) {
        width: 58px;
        height: 58px;
        border-color: color-mix(in srgb, var(--medal) 50%, var(--line-bright));
    }
    .top-three :global(.identity-copy strong) {
        font-size: 1.03rem;
    }

    .datum {
        color: var(--muted);
        font-size: 0.88rem;
        font-weight: 600;
        font-variant-numeric: tabular-nums;
    }
    .datum small {
        display: none;
    }
    .total b {
        color: var(--text);
        font-size: 1.1rem;
    }
    .top-three .total b {
        color: var(--medal);
        font-size: 1.45rem;
    }
    .distance {
        color: #d7b472;
    }
    .delta {
        color: var(--faint);
    }
    .delta.positive {
        color: var(--success);
    }
    .delta.negative {
        color: var(--danger);
    }

    .empty {
        margin-top: 2rem;
        padding: 4rem 2rem;
        text-align: center;
    }
    .empty span {
        color: var(--faint);
        font-size: 3rem;
    }
    .empty h2 {
        margin: 0.5rem 0;
        font-family: var(--display);
    }
    .empty p {
        color: var(--muted);
    }

    @media (max-width: 900px) {
        .board-head {
            position: absolute;
            width: 1px;
            height: 1px;
            overflow: hidden;
            clip: rect(0 0 0 0);
        }
        .board {
            display: grid;
            gap: 0.7rem;
            overflow: visible;
            border: 0;
            background: none;
        }
        .row {
            grid-template-columns: 42px minmax(0, 1fr) minmax(0, 1fr);
            gap: 0.85rem 1rem;
            min-height: 0;
            padding: 1rem;
            border: 1px solid var(--line);
            border-radius: var(--radius);
            background: #0e1118;
        }
        .row.top-three {
            min-height: 0;
            border: 1px solid color-mix(in srgb, var(--medal) 45%, var(--line));
            border-left: 4px solid var(--medal);
            background: linear-gradient(
                110deg,
                color-mix(in srgb, var(--medal) 11%, #151923),
                #0e1118 70%
            );
        }
        .row.top-ten:not(.top-three) {
            border-left: 3px solid var(--cyan);
        }
        .position {
            grid-row: 1 / span 3;
            align-self: start;
            padding-top: 0.65rem;
        }
        .identity-cell {
            grid-column: 2 / -1;
            padding-bottom: 0.75rem;
            border-bottom: 1px solid var(--line);
        }
        .datum {
            display: flex;
            flex-direction: column;
            gap: 0.25rem;
            font-size: 0.94rem;
        }
        .datum small {
            display: block;
            color: var(--faint);
            font-size: 0.62rem;
            font-weight: 750;
            letter-spacing: 0.05em;
            text-transform: uppercase;
        }
        .total b {
            font-size: 1.16rem;
        }
        .delta {
            grid-column: 2 / -1;
            padding-top: 0.1rem;
        }
        .top-three :global(.avatar) {
            width: 52px;
            height: 52px;
        }
    }

    @media (max-width: 520px) {
        .board {
            margin-top: 1.5rem;
        }
        .row {
            grid-template-columns: 34px minmax(0, 1fr) minmax(0, 1fr);
            gap: 0.8rem;
            padding: 0.85rem;
        }
        .position b {
            font-size: 1.05rem;
        }
        .top-three .position b {
            font-size: 1.2rem;
        }
        .position small {
            font-size: 0.46rem;
        }
        .top-three :global(.avatar) {
            width: 48px;
            height: 48px;
        }
        .top-three :global(.identity-copy strong) {
            font-size: 0.96rem;
        }
        .datum {
            font-size: 0.9rem;
        }
        .datum small {
            font-size: 0.59rem;
        }
        .top-three .total b {
            font-size: 1.25rem;
        }
    }
</style>
