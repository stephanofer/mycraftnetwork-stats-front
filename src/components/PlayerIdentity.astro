---
import type {
    PlayerRankIdentity,
    RankSummary,
} from "@/modules/ranks/rank.types";
import type { ResolvedSkin } from "@/modules/skins/skin.types";

interface Props {
    uuid: string;
    nickname: string;
    rank: RankSummary | PlayerRankIdentity | null;
    skin: ResolvedSkin;
    featured?: boolean;
    href?: string | null;
    eager?: boolean;
}

const {
    uuid,
    nickname,
    rank,
    skin,
    featured = false,
    href = `/player/${encodeURIComponent(nickname)}`,
    eager = false,
} = Astro.props;
const renderId = skin.renderId ?? uuid.replaceAll("-", "");
const image = featured
    ? `https://render.crafty.gg/3d/full/${renderId}`
    : `https://render.crafty.gg/3d/bust/${renderId}`;
const rankLabel = rank?.dominant.label ?? "Jugador";
const rankTheme = rank?.dominant.theme ?? "neutral";
const IdentityTag = href ? "a" : "div";
---

<IdentityTag
    class:list={["identity", { featured }]}
    href={href ?? undefined}
    aria-label={href ? `Ver perfil de ${nickname}` : undefined}
>
    <span class="avatar" aria-hidden="true">
        <img
            src={image}
            alt=""
            width={featured ? 150 : 48}
            height={featured ? 230 : 48}
            loading={eager ? "eager" : "lazy"}
            decoding="async"
        />
    </span>
    <span class="identity-copy">
        <strong>{nickname}</strong>
        <span class={`rank rank-${rankTheme}`}>{rankLabel}</span>
    </span>
</IdentityTag>

<style>
    .identity {
        display: inline-flex;
        min-width: 0;
        align-items: center;
        gap: 0.7rem;
    }
    .avatar {
        display: grid;
        width: 46px;
        height: 46px;
        flex: 0 0 auto;
        place-items: end center;
        overflow: hidden;
        border: 1px solid var(--line-bright);
        border-radius: 7px;
        background: radial-gradient(circle at 50% 20%, #273042, #10131b);
    }
    .avatar img {
        width: 100%;
        height: 100%;
        object-fit: contain;
        image-rendering: pixelated;
    }
    .identity-copy {
        display: flex;
        min-width: 0;
        flex-direction: column;
        align-items: flex-start;
        gap: 0.2rem;
    }
    strong {
        max-width: 100%;
        overflow: hidden;
        color: var(--text);
        font-family: var(--numeric);
        font-size: 0.9rem;
        text-overflow: ellipsis;
        white-space: nowrap;
    }
    .rank {
        padding: 0.08rem 0.38rem;
        border: 1px solid var(--line-bright);
        border-radius: 3px;
        color: var(--muted);
        font-size: 0.57rem;
        font-weight: 850;
        letter-spacing: 0.08em;
        line-height: 1.35;
        text-transform: uppercase;
    }
    .rank-gold {
        border-color: #8b6a29;
        color: #f0c568;
    }
    .rank-green {
        border-color: #287144;
        color: #70dc91;
    }
    .rank-aqua {
        border-color: #267d80;
        color: #6ae0dc;
    }
    .rank-purple {
        border-color: #68438d;
        color: #c792ef;
    }
    .rank-red,
    .rank-dark-red {
        border-color: #853a3a;
        color: #ff7770;
    }
    .rank-blue {
        border-color: #315d91;
        color: #75aef1;
    }
    .featured {
        display: grid;
        grid-template-columns: clamp(110px, 18vw, 165px) minmax(0, 1fr);
        align-items: center;
        gap: clamp(1rem, 3vw, 2rem);
        width: 100%;
    }
    .featured .avatar {
        width: clamp(110px, 18vw, 165px);
        height: clamp(170px, 28vw, 245px);
        border: 0;
        background: transparent;
        overflow: visible;
    }
    .featured strong {
        overflow: visible;
        font-family: var(--display);
        font-size: clamp(1.8rem, 5vw, 3.25rem);
        letter-spacing: -0.04em;
        overflow-wrap: anywhere;
        text-overflow: clip;
        white-space: normal;
    }
    .featured .rank {
        padding: 0.25rem 0.55rem;
        font-size: 0.7rem;
    }
    @media (max-width: 520px) {
        .featured {
            grid-template-columns: 90px minmax(0, 1fr);
            align-items: center;
            gap: 0.85rem;
        }
        .featured .avatar {
            width: 90px;
            height: 145px;
        }
        .featured strong {
            font-size: clamp(1.15rem, 5.8vw, 1.5rem);
            line-height: 1.05;
        }
    }
</style>
