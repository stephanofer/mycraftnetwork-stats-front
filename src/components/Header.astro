---
import PlayerSearch from "./PlayerSearch.astro";
const path = Astro.url.pathname;
---

<header class="header" data-header>
    <div class="shell header-inner">
        <a href="/" class="brand" aria-label="Mycraft Network, inicio">
            <img src="/images/favicon.webp" alt="" width="60" height="60" />
            <span
                ><b>Mycraft Network</b><small>IP: server.mycraft.es</small
                ></span
            >
        </a>

        <button
            class="menu-toggle"
            type="button"
            aria-expanded="false"
            aria-controls="main-menu"
            aria-label="Abrir menú"
            data-menu-toggle
        >
            <span></span><span></span><span></span>
        </button>

        <div class="menu" id="main-menu" data-menu>
            <nav aria-label="Navegación principal">
                <a
                    href="/ranking/rpg/kills"
                    aria-current={path.startsWith("/ranking/")
                        ? "page"
                        : undefined}>Rankings</a
                >
                <a
                    href="/rpg/clans"
                    aria-current={path.startsWith("/rpg/clans")
                        ? "page"
                        : undefined}>Clanes</a
                >
            </nav>
            <PlayerSearch />
            <a
                class="discord"
                href="https://discord.mycraft.es"
                rel="external noreferrer"
            >
                <span class="discord-icon"
                    ><svg
                        aria-hidden="true"
                        viewBox="0 0 24 24"
                        width="20"
                        height="20"
                        ><path
                            fill="currentColor"
                            d="M19.5 5.3A18 18 0 0 0 15 3.9l-.6 1.3a16.8 16.8 0 0 0-4.9 0l-.6-1.3a18.7 18.7 0 0 0-4.5 1.4C1.6 9.5.8 13.6 1.2 17.7a18.2 18.2 0 0 0 5.5 2.8l1.3-1.8-1.7-.8.4-.3c3.4 1.6 7.2 1.6 10.6 0l.5.3-1.8.8 1.4 1.8a18.2 18.2 0 0 0 5.4-2.8c.5-4.7-.8-8.8-3.3-12.4ZM8.3 15.2c-1 0-1.9-1-1.9-2.3 0-1.2.9-2.2 1.9-2.2s1.9 1 1.9 2.2c0 1.3-.9 2.3-1.9 2.3Zm7.4 0c-1 0-1.9-1-1.9-2.3 0-1.2.9-2.2 1.9-2.2s1.9 1 1.9 2.2c0 1.3-.8 2.3-1.9 2.3Z"
                        ></path></svg
                    ></span
                >
                <span class="discord-copy"
                    ><strong>Discord</strong><small
                        >Entrá y formá parte de la comunidad</small
                    ></span
                >
            </a>
        </div>
    </div>
</header>

<script>
    import gsap from "gsap";

    const header = document.querySelector<HTMLElement>("[data-header]");
    const toggle =
        header?.querySelector<HTMLButtonElement>("[data-menu-toggle]");
    const menu = header?.querySelector<HTMLElement>("[data-menu]");
    const menuItems = menu?.querySelectorAll<HTMLElement>(
        "nav a, .player-search, .discord",
    );
    const menuBars = toggle?.querySelectorAll<HTMLElement>("span");
    let menuTimeline: ReturnType<typeof gsap.timeline> | undefined;
    let isMobile = false;

    const setMenuOpen = (open: boolean) => {
        if (!header || !toggle) return;
        header.dataset.menuOpen = String(open);
        toggle.setAttribute("aria-expanded", String(open));
        toggle.setAttribute("aria-label", open ? "Cerrar menú" : "Abrir menú");
        menuTimeline?.[open ? "play" : "reverse"]();
    };

    const media = gsap.matchMedia();
    media.add(
        {
            mobile: "(max-width: 980px)",
            reduceMotion: "(prefers-reduced-motion: reduce)",
        },
        (context) => {
            const { mobile, reduceMotion } = context.conditions as {
                mobile: boolean;
                reduceMotion: boolean;
            };
            isMobile = mobile;
            if (!mobile || !toggle || !menu || !menuItems || !menuBars) return;

            const duration = reduceMotion ? 0 : 0.2;
            gsap.set(menu, { autoAlpha: 0, y: reduceMotion ? 0 : -12 });
            gsap.set(menuItems, { autoAlpha: 1, y: 0 });

            menuTimeline = gsap
                .timeline({
                    paused: true,
                    defaults: { ease: "power2.out" },
                })
                .to(menu, { autoAlpha: 1, y: 0, duration })
                .fromTo(
                    menuItems,
                    { autoAlpha: 0, y: reduceMotion ? 0 : -6 },
                    {
                        autoAlpha: 1,
                        y: 0,
                        duration: reduceMotion ? 0 : 0.16,
                        stagger: reduceMotion ? 0 : 0.025,
                    },
                    reduceMotion ? 0 : 0.045,
                )
                .to(
                    menuBars[0],
                    { y: 7, rotation: 45, duration },
                    0,
                )
                .to(menuBars[1], { autoAlpha: 0, duration }, 0)
                .to(
                    menuBars[2],
                    { y: -7, rotation: -45, duration },
                    0,
                );

            if (toggle.getAttribute("aria-expanded") === "true") {
                menuTimeline.progress(1);
            }

            return () => {
                menuTimeline?.kill();
                menuTimeline = undefined;
                isMobile = false;
                setMenuOpen(false);
                gsap.set([menu, ...menuItems, ...menuBars], {
                    clearProps: "opacity,visibility,transform",
                });
            };
        },
    );

    toggle?.addEventListener("click", () => {
        if (isMobile) {
            setMenuOpen(toggle.getAttribute("aria-expanded") !== "true");
        }
    });
    menu?.addEventListener("click", (event) => {
        if ((event.target as Element).closest("a")) setMenuOpen(false);
    });
    document.addEventListener("keydown", (event) => {
        if (
            event.key === "Escape" &&
            toggle?.getAttribute("aria-expanded") === "true"
        ) {
            setMenuOpen(false);
            toggle?.focus();
        }
    });
    document.addEventListener("click", (event) => {
        if (header && !header.contains(event.target as Node))
            setMenuOpen(false);
    });
</script>

<style>
    .header {
        position: sticky;
        top: 0;
        z-index: 50;
        border-bottom: 1px solid var(--line);
        background: rgb(7 9 13 / 88%);
        backdrop-filter: blur(14px);
    }
    .header-inner {
        display: grid;
        grid-template-columns: auto minmax(0, 1fr);
        min-height: 88px;
        align-items: center;
        gap: clamp(1.5rem, 4vw, 3.5rem);
    }
    .brand {
        display: flex;
        align-items: center;
        gap: 0.85rem;
        font-family: var(--display);
        line-height: 1;
    }
    .brand img {
        width: 60px;
        height: 60px;
    }
    .brand b,
    .brand small {
        display: block;
        white-space: nowrap;
    }
    .brand b {
        font-size: 1.25rem;
        font-weight: 550;
        letter-spacing: 0.02em;
    }
    .brand small {
        margin-top: 0.38rem;
        color: #b8beca;
        font-family: var(--body);
        font-size: 0.72rem;
        font-weight: 600;
        letter-spacing: 0.045em;
    }
    .menu {
        display: grid;
        grid-template-columns:
            minmax(max-content, 1fr) minmax(210px, 330px)
            auto;
        align-items: center;
        gap: clamp(1rem, 2.5vw, 2rem);
    }
    nav {
        display: flex;
        gap: clamp(1rem, 2.5vw, 2rem);
    }
    nav a {
        position: relative;
        padding-block: 1.8rem;
        color: var(--muted);
        font-size: 0.84rem;
        font-weight: 700;
    }
    nav a:hover,
    nav a[aria-current="page"] {
        color: var(--text);
    }
    nav a[aria-current="page"]::after {
        content: "";
        position: absolute;
        inset: auto 0 -1px;
        height: 2px;
        background: var(--accent);
    }
    .discord {
        position: relative;
        display: inline-flex;
        min-height: 42px;
        overflow: hidden;
        align-items: center;
        justify-content: center;
        gap: 0.55rem;
        padding: 0.45rem 0.8rem;
        border: 1px solid rgb(129 140 248 / 45%);
        border-radius: 9px;
        background: var(--surface-raised);
        color: white;
        font-size: 0.8rem;
        font-weight: 800;
        box-shadow:
            inset 0 1px rgb(255 255 255 / 7%),
            0 8px 24px rgb(0 0 0 / 20%);
        transition:
            transform 180ms ease,
            box-shadow 180ms ease,
            border-color 180ms ease;
    }
    .discord:hover {
        transform: translateY(-2px);
        border-color: #818cf8;
        box-shadow:
            inset 0 1px rgb(255 255 255 / 9%),
            0 12px 28px rgb(88 101 242 / 18%);
    }
    .discord-icon {
        display: grid;
        place-items: center;
        color: #aeb7ff;
    }
    .discord-copy strong,
    .discord-copy small {
        display: block;
    }
    .discord-copy small,
    .discord-arrow {
        display: none;
    }
    .menu-toggle {
        display: none;
    }

    @media (max-width: 980px) {
        .header-inner {
            position: relative;
            min-height: 78px;
        }
        .brand img {
            width: 54px;
            height: 54px;
        }
        .menu-toggle {
            display: grid;
            width: 44px;
            height: 44px;
            justify-self: end;
            place-content: center;
            gap: 5px;
            border: 1px solid var(--line-bright);
            border-radius: 10px;
            background: linear-gradient(145deg, var(--surface-raised), #0b0e14);
            color: var(--text);
            cursor: pointer;
            box-shadow: inset 0 1px rgb(255 255 255 / 5%);
            transition:
                border-color 180ms ease,
                box-shadow 180ms ease;
        }
        .header[data-menu-open="true"] .menu-toggle {
            border-color: var(--accent);
            box-shadow:
                0 0 0 3px rgb(228 87 46 / 10%),
                inset 0 1px rgb(255 255 255 / 6%);
        }
        .menu-toggle span {
            width: 20px;
            height: 2px;
            border-radius: 2px;
            background: currentColor;
        }
        .menu {
            position: fixed;
            inset: 78px 0 auto;
            width: 100vw;
            display: grid;
            grid-template-columns: 1fr;
            gap: 1rem;
            padding: 1.25rem max(1rem, calc((100vw - var(--page)) / 2));
            border-block: 1px solid var(--line);
            background: #090c11;
            box-shadow: 0 28px 70px rgb(0 0 0 / 58%);
            opacity: 0;
            visibility: hidden;
            transform: translateY(-14px);
            transform-origin: top;
            pointer-events: none;
        }
        .header[data-menu-open="true"] .menu {
            pointer-events: auto;
        }
        nav {
            display: grid;
            grid-template-columns: 1fr;
            gap: 0;
        }
        nav a {
            display: flex;
            align-items: center;
            min-height: 62px;
            padding: 0.7rem 0.15rem;
            font-size: 0.95rem;
            transition:
                color 180ms ease,
                padding-left 180ms ease;
        }
        nav a:hover {
            padding-left: 0.4rem;
        }
        nav a[aria-current="page"]::after {
            inset: auto auto -1px 0;
            width: 2.75rem;
            height: 2px;
        }
        :global(.player-search) {
            order: 2;
        }
        .discord {
            order: 3;
            width: 100%;
            min-height: 72px;
            justify-content: flex-start;
            gap: 0.85rem;
            padding: 0.7rem 0.85rem;
            border-color: rgb(129 140 248 / 38%);
            border-radius: 11px;
            background: var(--surface-raised);
        }
        .discord-icon {
            width: 42px;
            height: 42px;
            flex: 0 0 auto;
            border: 1px solid rgb(174 183 255 / 24%);
            border-radius: 10px;
            background: rgb(88 101 242 / 22%);
            color: #c5caff;
            box-shadow: inset 0 1px rgb(255 255 255 / 8%);
        }
        .discord-copy {
            min-width: 0;
            text-align: left;
        }
        .discord-copy strong {
            font-family: var(--display);
            font-size: 1rem;
            letter-spacing: 0.02em;
        }
        .discord-copy small {
            display: block;
            margin-top: 0.22rem;
            color: #aeb3bf;
            font-size: 0.68rem;
            font-weight: 500;
        }
    }

    @media (max-width: 420px) {
        .brand {
            gap: 0.6rem;
        }
        .brand img {
            width: 50px;
            height: 50px;
        }
        .brand b {
            font-size: 1.08rem;
        }
        .brand small {
            font-size: 0.63rem;
        }
        nav {
            grid-template-columns: 1fr;
        }
    }
</style>
