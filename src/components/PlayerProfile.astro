---
import type { PlayerProfile as Profile } from "@/modules/players/player.types";
import { formatDate, formatNumber, labelDuelMode, metricLabels, slugify } from "@/presentation";
import PlayerIdentity from "./PlayerIdentity.astro";

interface Props { player: Profile; }
const { player } = Astro.props;
const recognitionLabels: Record<string, string> = {
  "top-10-kills": "Top 10 en kills",
  "top-10-maxstreak": "Top 10 en mejor racha",
  "top-10-koth": "Top 10 en KOTH",
};
const duelStreaks = player.duels
  ? Object.entries(player.duels.streaks).sort((a, b) => b[1] - a[1])
  : [];
const unavailable = new Set(player.unavailableSections);
---

<article class="profile">
  <header class="hero panel reveal">
    <div>
      <p class="eyebrow">Perfil competitivo</p>
      <PlayerIdentity uuid={player.identity.uuid} nickname={player.identity.nickname} rank={player.rank} skin={player.skin} featured eager href={`/player/${encodeURIComponent(player.identity.nickname)}`} />
    </div>
    <div class="hero-meta">
      <span>RPG / TEMPORADA III</span>
      {player.clan && <a href={`/rpg/clans/${player.clan.id}/${slugify(player.clan.name)}`}><small>Clan actual</small><b>{player.clan.name}</b><em>{player.clan.role === "leader" ? "Líder" : player.clan.role === "elevated" ? "Oficial" : "Miembro"}</em></a>}
    </div>
  </header>

  {player.partialFailures.length > 0 && <aside class="warning" role="status"><strong>Perfil parcialmente disponible.</strong> No se pudieron cargar: {player.partialFailures.join(", ")}.</aside>}

  {player.recognitions === null ? (
    <section class="unavailable reveal" aria-label="Reconocimientos"><strong>Reconocimientos: sección no disponible</strong><span>No se pudieron comprobar las posiciones competitivas.</span></section>
  ) : player.recognitions.length > 0 && <section class="recognitions reveal" aria-label="Reconocimientos">
    {player.recognitions.map((item) => <span>✦ {recognitionLabels[item] ?? item}</span>)}
  </section>}

  <section class="positions reveal" aria-labelledby="positions-title">
    <div class="section-head"><div><span class="section-kicker">Clasificación</span><h2 id="positions-title" class="section-title">Posiciones de temporada</h2></div></div>
    {player.rankings === null || unavailable.has("rankings") ? <p class="unavailable"><strong>Posiciones: sección no disponible</strong><span>La clasificación no pudo consultarse.</span></p> : player.rankings.length ? <div class="position-grid">
      {player.rankings.map((item) => <a class="position-card panel" href={`/ranking/rpg/${item.metric}`}><span>{metricLabels[item.metric]}</span><strong class="number">#{item.position}</strong><small>{formatNumber(item.value)} total</small><em>{item.distanceToHigher === null ? "Líder o empatado" : `${formatNumber(item.distanceToHigher)} para superar al anterior`}</em></a>)}
    </div> : <p class="section-empty">Todavía no figura en las categorías de temporada.</p>}
  </section>

  <div class="content-grid">
    <section class="stat-section panel reveal" aria-labelledby="combat-title">
      <div class="section-head"><div><span class="section-kicker">RPG</span><h2 id="combat-title" class="section-title">Combate</h2></div><span class="index number">01</span></div>
      {player.combat ? <dl class="stat-grid">
        <div><dt>Kills</dt><dd class="number accent">{formatNumber(player.combat.kills)}</dd></div>
        <div><dt>Muertes</dt><dd class="number">{formatNumber(player.combat.deaths)}</dd></div>
        <div><dt>Racha actual</dt><dd class="number">{formatNumber(player.combat.streak)}</dd></div>
        <div><dt>Mejor racha</dt><dd class="number">{formatNumber(player.combat.maxStreak)}</dd></div>
        <div class="wide"><dt>Desconexiones en combate</dt><dd class="number danger">{formatNumber(player.combat.combatLogs)}</dd></div>
      </dl> : <p class="section-empty">Las estadísticas de combate no están disponibles.</p>}
    </section>

    <section class="stat-section panel reveal" aria-labelledby="koth-title">
      <div class="section-head"><div><span class="section-kicker">Dominio territorial</span><h2 id="koth-title" class="section-title">KOTH</h2></div><span class="index number">02</span></div>
      {player.koth === null || unavailable.has("koth") ? <p class="unavailable"><strong>KOTH: sección no disponible</strong><span>La fuente territorial no respondió.</span></p> : <>
        <div class="feature-stat"><span>Victorias totales</span><strong class="number">{formatNumber(player.koth.totalWins)}</strong></div>
        {player.koth.maps.length ? <div class="compact-list">{player.koth.maps.map((map) => <div><span>{map.name}</span><b class="number">{formatNumber(map.wins)}</b></div>)}</div> : <p class="section-empty">Sin victorias por mapa registradas.</p>}
        <p class="activity">Actividad registrada en KOTH: <time datetime={player.koth.recordedActivityAt?.toISOString()}>{formatDate(player.koth.recordedActivityAt)}</time></p>
      </>}
    </section>
  </div>

  <section class="duels panel reveal" aria-labelledby="duels-title">
    <div class="section-head"><div><span class="section-kicker">Cara a cara</span><h2 id="duels-title" class="section-title">Duelos</h2></div><span class="index number">03</span></div>
    {player.duels === null || unavailable.has("duels") ? <p class="unavailable"><strong>Duelos: sección no disponible</strong><span>No se pudieron recuperar sus enfrentamientos.</span></p> : <><div class="duel-summary">
      <div><span>Partidas</span><strong class="number">{formatNumber(player.duels.matches)}</strong></div><div><span>Victorias</span><strong class="number success">{formatNumber(player.duels.wins)}</strong></div><div><span>Derrotas</span><strong class="number">{formatNumber(player.duels.losses)}</strong></div><div><span>Win rate</span><strong class="number">{player.duels.winRate.toFixed(1)}%</strong></div><div><span>Kills / muertes</span><strong class="number">{formatNumber(player.duels.kills)} / {formatNumber(player.duels.deaths)}</strong></div>
    </div>
    {player.duels.modes.length ? <div class="mode-table"><div class="mode-head"><span>Modo</span><span>Partidas</span><span>V / D</span><span>K / M</span><span>Última actividad</span></div>{player.duels.modes.map((mode) => <div class="mode-row"><b>{labelDuelMode(mode.mode)}</b><span class="number">{formatNumber(mode.matches)}</span><span class="number">{mode.wins} / {mode.losses}</span><span class="number">{mode.kills} / {mode.deaths}</span><time datetime={mode.lastPlayedAt?.toISOString()}>{formatDate(mode.lastPlayedAt)}</time></div>)}</div> : <p class="section-empty">Sin duelos registrados en esta temporada.</p>}
    {duelStreaks.length > 0 && <div class="streaks"><h3>Rachas registradas</h3>{duelStreaks.map(([mode, value]) => <span><small>{labelDuelMode(mode)}</small><b class="number">{formatNumber(value)}</b></span>)}</div>}</>}
  </section>

  {player.clan ? <section class="clan-band reveal"><div><span class="section-kicker">Contribución actual</span><h2>{player.clan.name}</h2><p>{formatNumber(player.clan.kills)} kills · {formatNumber(player.clan.deaths)} muertes atribuidas al miembro</p></div><strong class="number">{player.clan.contributionPercent.toFixed(1)}<small>% aporte</small></strong><a class="button" href={`/rpg/clans/${player.clan.id}/${slugify(player.clan.name)}`}>Ver clan</a></section> : unavailable.has("clan") ? <section class="unavailable reveal"><strong>Clan: sección no disponible</strong><span>No se pudo comprobar la afiliación actual.</span></section> : null}
</article>

<style>
  .profile { display: grid; gap: 1.25rem; }
  .hero { position: relative; display: grid; grid-template-columns: 1fr auto; min-height: 310px; align-items: end; padding: clamp(1.25rem, 4vw, 3rem); overflow: hidden; }
  .hero::before { content: ""; position: absolute; width: 420px; height: 420px; left: -100px; bottom: -300px; border-radius: 50%; background: var(--accent); filter: blur(100px); opacity: .18; }
  .hero > * { position: relative; }
  .hero-meta { display: flex; flex-direction: column; align-items: flex-end; gap: 1rem; color: var(--faint); font-size: .65rem; letter-spacing: .12em; }
  .hero-meta a { min-width: 170px; padding: .8rem; border: 1px solid var(--line); background: rgb(0 0 0 / 20%); letter-spacing: 0; }
  .hero-meta small, .hero-meta b, .hero-meta em { display: block; }
  .hero-meta small { color: var(--faint); text-transform: uppercase; } .hero-meta b { margin-top: .15rem; color: var(--text); font-family: var(--display); font-size: 1.1rem; } .hero-meta em { color: var(--accent-bright); font-size: .7rem; font-style: normal; }
  .warning { padding: .8rem 1rem; border: 1px solid #6e572d; border-radius: 7px; background: #1d1911; color: #d9c797; font-size: .8rem; }
  .unavailable { display: flex; flex-direction: column; gap: .2rem; margin: 1rem 0 0; padding: .9rem 1rem; border: 1px solid #6e572d; border-radius: 7px; background: #1d1911; color: #d9c797; font-size: .78rem; font-style: normal; }
  .unavailable span { color: #a99b79; font-size: .7rem; }
  .recognitions { display: flex; flex-wrap: wrap; gap: .5rem; } .recognitions span { padding: .45rem .7rem; border: 1px solid #64512e; border-radius: 100px; color: var(--gold); font-size: .72rem; }
  .positions { margin-top: 1.5rem; }
  .section-head { display: flex; align-items: flex-start; justify-content: space-between; gap: 1rem; margin-bottom: 1.2rem; }
  .index { color: var(--faint); }
  .position-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: .75rem; margin-top: 1rem; }
  .position-card { display: grid; grid-template-columns: 1fr auto; padding: 1rem; box-shadow: none; transition: transform 180ms ease, border-color 180ms ease; }
  .position-card:hover { transform: translateY(-3px); border-color: var(--accent); }
  .position-card > span { color: var(--muted); font-size: .72rem; text-transform: uppercase; } .position-card > strong { grid-row: span 2; color: var(--accent-bright); font-size: 2rem; } .position-card small { color: var(--text); } .position-card em { grid-column: 1 / -1; margin-top: .7rem; color: var(--faint); font-size: .67rem; font-style: normal; }
  .content-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; }
  .stat-section, .duels { padding: clamp(1.1rem, 3vw, 1.8rem); box-shadow: none; }
  dl { margin: 0; }
  .stat-grid { display: grid; grid-template-columns: 1fr 1fr; }
  .stat-grid div { padding: 1rem 0; border-top: 1px solid var(--line); } .stat-grid div:nth-child(odd) { padding-right: 1rem; border-right: 1px solid var(--line); } .stat-grid div:nth-child(even) { padding-left: 1rem; } .stat-grid .wide { grid-column: 1 / -1; border-right: 0; }
  dt, .feature-stat span, .duel-summary span { color: var(--muted); font-size: .72rem; } dd { margin: .2rem 0 0; font-size: 1.5rem; } .accent { color: var(--accent-bright); } .danger { color: var(--danger); } .success { color: var(--success); }
  .feature-stat { display: flex; align-items: end; justify-content: space-between; padding: 1rem 0; border-block: 1px solid var(--line); } .feature-stat strong { color: var(--gold); font-size: 2.6rem; }
  .compact-list div { display: flex; justify-content: space-between; padding: .65rem 0; border-bottom: 1px solid var(--line); font-size: .8rem; } .compact-list span { color: var(--muted); }
  .activity, .section-empty { margin: 1rem 0 0; color: var(--faint); font-size: .72rem; }
  .duel-summary { display: grid; grid-template-columns: repeat(5, 1fr); border-block: 1px solid var(--line); } .duel-summary div { padding: 1rem; border-right: 1px solid var(--line); } .duel-summary div:first-child { padding-left: 0; } .duel-summary div:last-child { border: 0; } .duel-summary strong, .duel-summary span { display: block; } .duel-summary strong { margin-top: .3rem; font-size: 1.2rem; }
  .mode-table { margin-top: 1rem; } .mode-head, .mode-row { display: grid; grid-template-columns: 1.3fr repeat(3, .7fr) 1fr; gap: 1rem; padding: .65rem; align-items: center; } .mode-head { color: var(--faint); font-size: .62rem; text-transform: uppercase; } .mode-row { border-top: 1px solid var(--line); color: var(--muted); font-size: .75rem; } .mode-row b { color: var(--text); }
  .streaks { display: flex; flex-wrap: wrap; align-items: end; gap: .6rem; margin-top: 1.2rem; } .streaks h3 { width: 100%; margin: 0; font-size: .8rem; } .streaks span { min-width: 110px; padding: .6rem; border: 1px solid var(--line); } .streaks small, .streaks b { display: block; } .streaks small { color: var(--faint); } .streaks b { margin-top: .25rem; }
  .clan-band { display: grid; grid-template-columns: 1fr auto auto; align-items: center; gap: 2rem; padding: 1.5rem; border: 1px solid var(--line); border-left: 3px solid var(--cyan); background: linear-gradient(90deg, rgb(85 214 190 / 8%), transparent); } .clan-band h2, .clan-band p { margin: 0; } .clan-band h2 { font-family: var(--display); } .clan-band p { color: var(--muted); font-size: .75rem; } .clan-band > strong { color: var(--cyan); font-size: 2rem; } .clan-band > strong small { display: block; font-family: var(--body); font-size: .6rem; text-transform: uppercase; }
  @media (max-width: 800px) { .content-grid { grid-template-columns: 1fr; } .duel-summary { grid-template-columns: repeat(2, 1fr); } .duel-summary div { border-bottom: 1px solid var(--line); } .mode-head { display: none; } .mode-row { grid-template-columns: 1fr 1fr; } .mode-row time { grid-column: 1 / -1; } }
  @media (max-width: 600px) { .hero { grid-template-columns: 1fr; } .hero-meta { align-items: stretch; } .position-grid { grid-template-columns: 1fr; } .clan-band { grid-template-columns: 1fr auto; } .clan-band .button { grid-column: 1 / -1; } }
</style>
