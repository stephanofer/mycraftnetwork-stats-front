<section class="modes" aria-labelledby="modes-title" data-modes>
    <div class="intro">
        <p class="eyebrow">Centro competitivo</p>
        <h1 id="modes-title">Modalidades</h1>
        <p>
            Estadisticas de la Temporadas y rivalidades. Datos competitivos
            reales, con actualizaciones periódicas.
        </p>
    </div>
    <div class="mode-grid">
        <a class="mode rpg" href="/ranking/rpg/kills">
            <img
                src="/images/image1.webp"
                alt="Paisaje de la modalidad RPG"
                width="700"
                height="460"
                fetchpriority="high"
            />
            <span class="shade"></span>
            <span class="status active"><i></i> Temporada activa</span>
            <span class="copy">
                <small>RPG / TEMPORADA III</small>
                <strong>Survival RPG 1.8.9</strong>
                <span
                    >Rankings, perfiles de combate y clanes en una temporada que
                    ya está en marcha.</span
                >
                <b>Entrar a competir <span aria-hidden="true">↗</span></b>
            </span>
        </a>
        <article class="mode smp">
            <img
                src="/images/image2.webp"
                alt="Paisaje de la modalidad Survival 26.2"
                width="700"
                height="460"
            />
            <span class="shade"></span>
            <span class="status">Próximamente</span>
            <span class="copy">
                <small>EN CONSTRUCCIÓN</small>
                <strong>Survival RPG 26.2</strong>
                <span
                    >Rankings, perfiles de combate y clanes en una temporada que
                    pronto estará en marcha</span
                >
                <b>Muy pronto</b>
            </span>
        </article>
    </div>
</section>

<script>
    import gsap from "gsap";

    const section = document.querySelector<HTMLElement>("[data-modes]");

    if (section) {
        const introItems = section.querySelectorAll<HTMLElement>(".intro > *");
        const cards = Array.from(
            section.querySelectorAll<HTMLElement>(".mode"),
        );
        const hoverCards = cards.filter(
            (card) => !card.classList.contains("smp"),
        );
        const media = gsap.matchMedia();

        media.add("(prefers-reduced-motion: no-preference)", () => {
            const entrance = gsap.timeline({
                defaults: { duration: 0.38, ease: "power2.out" },
            });

            entrance
                .from(introItems, {
                    autoAlpha: 0,
                    y: 12,
                    stagger: 0.05,
                    clearProps: "opacity,visibility,transform",
                })
                .from(
                    cards,
                    {
                        autoAlpha: 0,
                        y: 16,
                        duration: 0.46,
                        stagger: 0.07,
                        clearProps: "opacity,visibility,transform",
                    },
                    "-=0.2",
                );
        });

        media.add(
            "(hover: hover) and (pointer: fine) and (prefers-reduced-motion: no-preference)",
            () => {
                const cleanups = hoverCards.map((card) => {
                    const image = card.querySelector<HTMLImageElement>("img");
                    const arrow =
                        card.querySelector<HTMLElement>(".copy b span");

                    const enter = () => {
                        gsap.to(card, {
                            y: -5,
                            duration: 0.22,
                            ease: "power2.out",
                            overwrite: "auto",
                        });
                        gsap.to(image, {
                            scale: 1.045,
                            duration: 0.32,
                            ease: "power2.out",
                            overwrite: "auto",
                        });
                        gsap.to(arrow, {
                            x: 3,
                            y: -3,
                            duration: 0.2,
                            ease: "power2.out",
                            overwrite: "auto",
                        });
                    };
                    const leave = () => {
                        gsap.to(card, {
                            y: 0,
                            duration: 0.26,
                            ease: "power2.out",
                            overwrite: "auto",
                        });
                        gsap.to(image, {
                            scale: 1,
                            duration: 0.3,
                            ease: "power2.out",
                            overwrite: "auto",
                        });
                        gsap.to(arrow, {
                            x: 0,
                            y: 0,
                            duration: 0.22,
                            ease: "power2.out",
                            overwrite: "auto",
                        });
                    };
                    const blur = (event: FocusEvent) => {
                        if (!card.contains(event.relatedTarget as Node))
                            leave();
                    };

                    card.addEventListener("mouseenter", enter);
                    card.addEventListener("mouseleave", leave);
                    card.addEventListener("focus", enter);
                    card.addEventListener("blur", blur);

                    return () => {
                        card.removeEventListener("mouseenter", enter);
                        card.removeEventListener("mouseleave", leave);
                        card.removeEventListener("focus", enter);
                        card.removeEventListener("blur", blur);
                        gsap.killTweensOf([card, image, arrow]);
                    };
                });

                return () => cleanups.forEach((cleanup) => cleanup());
            },
        );
    }
</script>

